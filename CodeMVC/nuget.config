<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- SDK được tiêu thụ dạng gói đóng gói (dotnet pack CodeSDK -> đây). Đúng ý "dùng lại DLL build từ SDK". -->
    <add key="local-feed" value="./local-feed" />
  </packageSources>
</configuration>
